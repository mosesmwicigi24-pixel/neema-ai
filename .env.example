POSTGRES_DB=neema
POSTGRES_USER=neema
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql+asyncpg://neema:CHANGE_ME@postgres:5432/neema
DATABASE_URL_SYNC=postgresql+psycopg2://neema:CHANGE_ME@postgres:5432/neema
PGADMIN_EMAIL=admin@bethanyhouse.co.ke
PGADMIN_PASSWORD=your_secure_password
REDIS_URL=redis://redis:6379/0
ENVIRONMENT=production
API_PORT=8000
SECRET_KEY=RUN__python3 -c "import secrets; print(secrets.token_urlsafe(48))"
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=https://your-domain.com
N8N_API_SECRET=RUN__openssl rand -base64 48
WABA_TOKEN=GET_FROM_META_DEVELOPER_PORTAL
WABA_PHONE_NUMBER_ID=GET_FROM_META_DEVELOPER_PORTAL
WABA_API_VERSION=v21.0
NEXTAUTH_SECRET=RUN__openssl rand -base64 48
NEXTAUTH_URL=https://your-domain.com
NEXT_PUBLIC_API_URL=https://your-domain.com/api
NEXT_PUBLIC_WS_URL=wss://your-domain.com
API_INTERNAL_URL=http://api:8000
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME
N8N_HOST=your-domain.com
WEBHOOK_URL=https://your-domain.com/n8n/
OPENAI_API_KEY=sk-CHANGE_ME
MEDIA_STORAGE_PATH=/var/www/neema/media
MEDIA_PUBLIC_URL=https://your-domain/api/admin