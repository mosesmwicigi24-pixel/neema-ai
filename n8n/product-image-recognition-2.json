    {
      "parameters": {
        "resource": "image",
        "operation": "analyze",
        "modelId": {
          "__rl": true,
          "value": "gpt-4o",
          "mode": "list",
          "cachedResultName": "GPT-4O"
        },
        "text": "You are an expert for Clergy Apparels, and Christian Gifts. When given an image of a vestment or church product, identify the item, describe it professionally. suggest possible close names. If the image captures different separate items, always focus on the primary object in the image. If the image captures one item with multiple clergy items, ensure to mention all of them.  Make the description brief and capture features more. ",
        "inputType": "base64",
        "options": {}
      },
