    {
      "parameters": {
        "jsCode": "// Extract image media info from the WhatsApp payload passed in\nconst msg = $json.messages[0];\nconst imageObj = msg.image || {};\nconst media_url = imageObj.url || '';\nconst caption   = imageObj.caption || '';\nconst msgText   = caption || '[image received]';\n\nreturn [{ json: {\n  wa_id:      $json.contacts[0].wa_id,\n  name:       $json.contacts[0].profile.name || '',\n  phone:      String(msg.from).replace(/[^\\d]/g, ''),\n  msgId:      msg.id,\n  tsMs:       Number(msg.timestamp || 0) * 1000,\n  tsIso:      new Date(Number(msg.timestamp || 0) * 1000).toISOString(),\n  media_type: 'image',\n  media_id:   imageObj.id || '',\n  media_url,\n  mime_type:  imageObj.mime_type || 'image/jpeg',\n  msgText,\n  caption,\n  _raw: $json,\n}}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        0
      ],
      "id": "83c8732b-b7d5-4845-b3a9-e81423de6ace",
