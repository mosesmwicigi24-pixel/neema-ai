    {
      "parameters": {
        "jsCode": "// Merge the stable_url back onto the original media info\nconst download = $json; // response from Download Media API\nconst extract  = $('Extract Image Info').item.json;\n\nconst stable_url = download.ok\n  ? download.stable_url\n  : extract.media_url; // fall back to original WhatsApp URL if download failed\n\nreturn [{ json: {\n  ...extract,\n  media_url: stable_url,  // overwrite with stable internal URL\n  download_ok: download.ok ?? false,\n}}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
