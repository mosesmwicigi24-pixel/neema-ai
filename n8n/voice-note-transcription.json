        "jsonBody": "={\n  \"wa_id\":         {{ JSON.stringify(String($('Extract Audio Info').item.json.wa_id)) }},\n  \"name\":          {{ JSON.stringify(String($('Extract Audio Info').item.json.name || \"\")) }},\n  \"direction\":     \"inbound\",\n  \"text\":          {{ JSON.stringify($('Transcribe Audio').item.json.text || \"\") }},\n  \"media_type\":    \"audio\",\n  \"media_url\":     {{ JSON.stringify($('Download Media API').item.json.stable_url) }},\n  \"media_caption\": {{ JSON.stringify($('Extract Audio Info').item.json.caption || \"\") }},\n  \"ts_ms\":         {{ $('Extract Audio Info').item.json.tsMs }},\n  \"ts_iso\":        {{ JSON.stringify($('Extract Audio Info').item.json.tsIso) }}\n}",
