    {
      "parameters": {
        "jsCode": "// Extract audio media info from the WhatsApp payload passed in\nconst msg = $json.messages[0];\nconst mediaObj = msg.audio || {};\nconst media_url = mediaObj.url || '';\nconst caption   = mediaObj.caption || '';\nconst msgText   = caption || '[audio received]';\n\nreturn [{ json: {\n  wa_id:      $json.contacts[0].wa_id,\n  name:       $json.contacts[0].profile.name || '',\n  phone:      String($json.messages[0].from).replace(/[^\\d]/g, ''),\n  msgId:      msg.id,\n  tsMs:       Number(msg.timestamp || 0) * 1000,\n  tsIso:      new Date(Number(msg.timestamp || 0) * 1000).toISOString(),\n  media_type: 'audio',\n  media_id:   mediaObj.id || '',\n  media_url,\n  mime_type:  mediaObj.mime_type || 'audio/ogg',\n  msgText,\n  caption,\n  filename:   'voice_message.ogg',\n  _raw: $json,\n}}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        0
      ],
      "id": "9d5c96b5-743d-4f88-90ed-e2732278f18f",
      "name": "Extract Audio Info"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://neema.bethanyhouse.co.ke/api/n8n/media/download",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-n8n-secret",
              "value": "REPLACE_WITH_N8N_API_SECRET"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "media_url",
              "value": "={{ $json.media_url }}"
            },
            {
              "name": "media_id",
              "value": "={{ $json.media_id }}"
            },
            {
              "name": "mime_type",
              "value": "={{ $json.mime_type }}"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        480,
        0
      ],
      "id": "84ec2a97-0858-447f-bc22-03692c8dda1d",
